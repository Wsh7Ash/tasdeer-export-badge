{
  "name": "tasdeer-export-badge",
  "version": "1.0.0",
  "description": "Browser extension for identifying Gulf-made products on e-commerce sites",
  "main": "src/background/service-worker.js",
  "scripts": {
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "watch": "webpack --mode=development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "package": "npm run build && zip -r tasdeer-export-badge.zip dist/",
    "clean": "rm -rf dist/ coverage/"
  },
  "keywords": [
    "browser-extension",
    "e-commerce",
    "gulf-countries",
    "made-in-saudi",
    "made-in-uae",
    "product-origin",
    "chrome-extension",
    "firefox-addon"
  ],
  "author": "Wsh7Ash <wsh7ash@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wsh7Ash/tasdeer-export-badge.git"
  },
  "bugs": {
    "url": "https://github.com/Wsh7Ash/tasdeer-export-badge/issues"
  },
  "homepage": "https://github.com/Wsh7Ash/tasdeer-export-badge#readme",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "zip": "^1.2.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "webextensions": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "globals": {
      "chrome": "readonly",
      "browser": "readonly"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100
  }
}
