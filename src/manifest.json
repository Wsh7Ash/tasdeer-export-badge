{
  "manifest_version": 3,
  "name": "Tasdeer Export Badge",
  "version": "1.0.0",
  "description": "Highlight local products from Gulf countries on e-commerce sites",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.amazon.sa/*",
    "https://*.amazon.ae/*",
    "https://*.noon.com/*",
    "https://*.jarir.com/*",
    "https://*.extra.com/*",
    "https://*.carrefouruae.com/*",
    "https://*.luluhypermarket.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.amazon.sa/*", "https://*.amazon.ae/*"],
      "js": ["content/amazon.js"],
      "css": ["styles/badges.css"]
    },
    {
      "matches": ["https://*.noon.com/*"],
      "js": ["content/noon.js"],
      "css": ["styles/badges.css"]
    },
    {
      "matches": ["https://*.jarir.com/*"],
      "js": ["content/jarir.js"],
      "css": ["styles/badges.css"]
    },
    {
      "matches": ["https://*.extra.com/*"],
      "js": ["content/extra.js"],
      "css": ["styles/badges.css"]
    },
    {
      "matches": ["https://*.carrefouruae.com/*"],
      "js": ["content/carrefour.js"],
      "css": ["styles/badges.css"]
    },
    {
      "matches": ["https://*.luluhypermarket.com/*"],
      "js": ["content/lulu.js"],
      "css": ["styles/badges.css"]
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
